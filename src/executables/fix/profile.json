{
  "name": "fix",
  "role": "primitive",
  "describe": "Apply review feedback to an existing PR branch.",
  "inputs": [
    {
      "name": "pr",
      "flag": "--pr",
      "type": "int",
      "required": true,
      "describe": "GitHub PR number to apply feedback to."
    },
    {
      "name": "feedback",
      "flag": "--feedback",
      "type": "string",
      "required": false,
      "describe": "Inline override. If absent, the flow reads the latest PR review comment."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "systemPromptAppend": null,
    "tools": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob"
    ],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:fixing",
          "color": "e99695",
          "description": "kody2: applying review feedback"
        }
      },
      {
        "script": "fixFlow"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "loadCoverageRules"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      { "script": "parseAgentResult" },
      { "script": "requireFeedbackActions" },
      { "script": "verify" },
      { "script": "checkCoverageWithRetry" },
      { "script": "commitAndPush" },
      { "script": "riskGate" },
      { "script": "ensurePr",         "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "postIssueComment", "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "writeRunSummary" },
      { "script": "saveTaskState",    "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "advanceFlow",      "runWhen": { "data.riskGate.decision": "allow" } }
    ]
  },
  "output": {
    "actionTypes": [
      "FIX_COMPLETED",
      "FIX_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
