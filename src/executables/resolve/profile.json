{
  "name": "resolve",
  "describe": "Resolve merge conflicts between a PR branch and the default branch.",

  "inputs": [
    {
      "name": "pr",
      "flag": "--pr",
      "type": "int",
      "required": true,
      "describe": "GitHub PR number whose branch has conflicts with the default branch."
    }
  ],

  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "systemPromptAppend": null,
    "tools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob"],
    "hooks": {
      "PreToolUse": [],
      "PostToolUse": [],
      "Stop": []
    },
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },

  "cliTools": [],

  "scripts": {
    "preflight": [
      { "script": "resolveFlow" },
      { "script": "loadTaskState" },
      { "script": "loadConventions" },
      { "script": "loadCoverageRules" },
      { "script": "composePrompt" }
    ],
    "postflight": [
      { "script": "parseAgentResult" },
      { "script": "commitAndPush" },
      { "script": "ensurePr" },
      { "script": "postIssueComment" },
      { "script": "writeRunSummary" },
      { "script": "saveTaskState" }
    ]
  },
  "output": {
    "actionTypes": [
      "RESOLVE_COMPLETED",
      "RESOLVE_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
