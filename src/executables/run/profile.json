{
  "name": "run",
  "role": "primitive",
  "describe": "Implement a GitHub issue end-to-end: branch, code, commit, open PR.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to implement."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "systemPromptAppend": null,
    "tools": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob"
    ],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:running",
          "color": "fbca04",
          "description": "kody2: implementing the change"
        }
      },
      {
        "script": "runFlow"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "resolveArtifacts"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "loadCoverageRules"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      { "script": "parseAgentResult" },
      { "script": "requirePlanDeviations" },
      { "script": "verify" },
      { "script": "checkCoverageWithRetry" },
      { "script": "commitAndPush" },
      { "script": "riskGate" },
      { "script": "ensurePr",          "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "postIssueComment",  "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "writeRunSummary" },
      { "script": "saveTaskState",     "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "mirrorStateToPr",   "runWhen": { "data.riskGate.decision": "allow" } },
      { "script": "advanceFlow",       "runWhen": { "data.riskGate.decision": "allow" } }
    ]
  },
  "input": {
    "artifacts": [
      { "name": "plan", "required": false }
    ]
  },
  "output": {
    "actionTypes": [
      "RUN_COMPLETED",
      "RUN_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
